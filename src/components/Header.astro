---
import type { Locale } from '../i18n/ui';
import { t, otherLocale, localizedPath } from '../i18n/ui';
import { profile } from '../data/profile';

type Props = { locale: Locale };
const { locale } = Astro.props;
const altLocale = otherLocale(locale);
const homeHref = localizedPath(locale);
const altHref = localizedPath(altLocale);
---

<header class="site-header">
  <div class="site-header__inner">
    <a href={homeHref} class="site-header__brand">
      {profile.shortName} <span style="color: var(--ink-mute); font-weight: 400; margin: 0 0.2rem;">/</span>
      {profile.shortNameAlt}
    </a>
    <nav class="site-nav" aria-label="Primary">
      <a href={profile.cvUrl} target="_blank" rel="noopener noreferrer">{t(locale, 'nav.cv')}</a>
      <span class="site-nav__sep">·</span>
      <a href={`mailto:${profile.emailAddress}`}>{t(locale, 'nav.email')}</a>
      <span class="site-nav__sep">·</span>
      <a href={profile.social.scholar} target="_blank" rel="noopener noreferrer">{t(locale, 'nav.scholar')}</a>
      <span class="site-nav__sep">·</span>
      <a href={profile.social.github} target="_blank" rel="noopener noreferrer">{t(locale, 'nav.github')}</a>
      <span class="site-nav__sep">·</span>
      <a href={profile.social.linkedin} target="_blank" rel="noopener noreferrer">{t(locale, 'nav.linkedin')}</a>
      <a href={altHref} class="lang-switch" aria-label="Switch language">{t(locale, 'nav.lang_other')}</a>
    </nav>
  </div>
</header>
