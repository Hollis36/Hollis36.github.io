---
import { profile } from '../data/profile';
---

<section class="hero">
  <div class="hero__text">
    <h1 class="hero__name">{profile.name}</h1>
    <p class="hero__position">{profile.position}</p>
    <p class="hero__affiliation">{profile.affiliation}</p>
    <p class="hero__goal"><strong>Goal:</strong> {profile.goal}</p>
    <p class="hero__interests"><strong>Research Interests:</strong> {profile.interests}</p>
  </div>
  <div class="hero__avatar">
    <img src={profile.avatarUrl} alt={profile.name} width="200" height="200" loading="eager" />
  </div>
</section>
