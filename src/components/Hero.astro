---
import type { Locale } from '../i18n/ui';
import { t } from '../i18n/ui';
import { profile } from '../data/profile';

type Props = { locale: Locale };
const { locale } = Astro.props;
const lp = profile.locales[locale];
---

<section class="hero">
  <div class="hero__text">
    <h1 class="hero__name">
      {lp.name}
      {locale === 'en' ? (
        <span class="hero__name-alt">/ {profile.locales.zh.name}</span>
      ) : (
        <span class="hero__name-alt">/ {profile.locales.en.name}</span>
      )}
    </h1>
    <p class="hero__position">{lp.position}</p>
    <p class="hero__affiliation">{lp.affiliation}</p>
    <p class="hero__goal"><strong>{t(locale, 'hero.goal')}:</strong> {lp.goal}</p>
    <p class="hero__interests"><strong>{t(locale, 'hero.interests')}:</strong> {lp.interests}</p>
  </div>
  <div class="hero__avatar">
    <img src={profile.avatarUrl} alt={lp.name} width="200" height="200" loading="eager" />
  </div>
</section>
