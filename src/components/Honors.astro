---
import type { Locale } from '../i18n/ui';
import { profile } from '../data/profile';

type Props = { locale: Locale };
const { locale } = Astro.props;

const sorted = [...profile.honorsAwards].sort((a, b) => b.year - a.year);
---

<ul class="honors">
  {sorted.map((row) => {
    const label = locale === 'zh' ? row.zh : row.en;
    return (
      <li class="honors__item">
        <span class="honors__year">{row.year}</span>
        <span class="honors__label">
          {row.link ? (
            <a href={row.link} target="_blank" rel="noopener noreferrer">{label}</a>
          ) : (
            <span>{label}</span>
          )}
          {row.note && <span class="honors__note">— {row.note}</span>}
        </span>
      </li>
    );
  })}
</ul>
