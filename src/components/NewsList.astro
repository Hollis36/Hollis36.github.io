---
import { getCollection, render } from 'astro:content';
import type { Locale } from '../i18n/ui';

type Props = { locale: Locale };
const { locale } = Astro.props;

const all = await getCollection('news', (entry) => entry.id.startsWith(`${locale}/`));
const sorted = all.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const items = await Promise.all(
  sorted.map(async (entry) => {
    const { Content } = await render(entry);
    const d = entry.data.date;
    const dateLabel = `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}`;
    return { id: entry.id, dateLabel, Content };
  })
);
---

<ul class="news-list">
  {items.map(({ id, dateLabel, Content }) => (
    <li class="news-list__item" id={`news-${id}`}>
      <time class="news-list__date">{dateLabel}</time>
      <div class="news-list__content"><Content /></div>
    </li>
  ))}
</ul>
