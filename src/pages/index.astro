---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionTitle from '../components/SectionTitle.astro';
import Education from '../components/Education.astro';
import Experience from '../components/Experience.astro';
import NewsList from '../components/NewsList.astro';
import PublicationItem from '../components/PublicationItem.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Honors from '../components/Honors.astro';
import ReviewerServiceComp from '../components/ReviewerService.astro';
import { getCollection } from 'astro:content';
import papersData from '../data/papers.json';
import { profile } from '../data/profile';

type PaperMeta = (typeof papersData)[keyof typeof papersData];
const meta = papersData as Record<string, PaperMeta>;

const pubs = await getCollection('publications');
const pubsWithMeta = pubs
  .map((p) => ({ entry: p, m: meta[p.data.paperId] }))
  .filter((x): x is { entry: typeof pubs[number]; m: PaperMeta } => Boolean(x.m))
  .sort((a, b) => b.m.year - a.m.year);

const projects = await getCollection('projects');
const projectsSorted = projects.sort((a, b) =>
  a.data.order !== b.data.order ? a.data.order - b.data.order : b.data.year - a.data.year
);

const pageTitle = 'Academic Portfolio';
const pageDescription = profile.goal;
const hasReviewer = profile.reviewerService.length > 0;
const hasProjects = projectsSorted.length > 0;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Hero />
  <hr />

  <section class="section">
    <SectionTitle title="News" id="news" />
    <NewsList />
  </section>
  <hr />

  <section class="section">
    <SectionTitle title="Education" id="education" />
    <Education />
  </section>
  <hr />

  <section class="section">
    <SectionTitle title="Experience" id="experience" />
    <Experience />
  </section>
  <hr />

  <section class="section">
    <SectionTitle title="Publications" id="publications" />
    <ul class="pub-list">
      {pubsWithMeta.map(({ entry, m }) => (
        <PublicationItem
          uid={entry.data.paperId}
          title={entry.data.title}
          abstract={entry.data.abstract}
          note={entry.data.note}
          meta={m as any}
        />
      ))}
    </ul>
  </section>

  <hr />
  <section class="section">
    <SectionTitle title="Honors & Awards" id="honors" />
    <Honors />
  </section>

  {hasProjects && (
    <>
      <hr />
      <section class="section">
        <SectionTitle title="Selected Projects" id="projects" />
        <ul class="project-grid">
          {projectsSorted.map((p) => (
            <ProjectCard
              title={p.data.title}
              summary={p.data.summary}
              cover={p.data.cover}
              link={p.data.link}
            />
          ))}
        </ul>
      </section>
    </>
  )}

  {hasReviewer && (
    <>
      <hr />
      <section class="section">
        <SectionTitle title="Reviewer Service" id="reviewer" />
        <ReviewerServiceComp />
      </section>
    </>
  )}
</BaseLayout>

<script>
  import '../scripts/bibtex-copy';
</script>
