---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionTitle from '../components/SectionTitle.astro';
import NewsList from '../components/NewsList.astro';
import PublicationItem from '../components/PublicationItem.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ReviewerServiceComp from '../components/ReviewerService.astro';
import { getCollection } from 'astro:content';
import papersData from '../data/papers.json';
import { profile } from '../data/profile';
import { t } from '../i18n/ui';

const locale = 'en';
const lp = profile.locales[locale];

type PaperMeta = (typeof papersData)[keyof typeof papersData];
const meta = papersData as Record<string, PaperMeta>;

const pubs = await getCollection('publications', (e) => e.id.startsWith(`${locale}/`));
const pubsWithMeta = pubs
  .map((p) => ({ entry: p, m: meta[p.data.paperId] }))
  .filter((x): x is { entry: typeof pubs[number]; m: PaperMeta } => Boolean(x.m))
  .sort((a, b) => b.m.year - a.m.year);

const projects = await getCollection('projects', (e) => e.id.startsWith(`${locale}/`));
const projectsSorted = projects.sort((a, b) =>
  a.data.order !== b.data.order ? a.data.order - b.data.order : b.data.year - a.data.year
);

const pageTitle = `${lp.name} | ${lp.position}`;
const pageDescription = lp.goal;
---

<BaseLayout locale={locale} title={pageTitle} description={pageDescription}>
  <Hero locale={locale} />
  <hr />

  <section class="section">
    <SectionTitle title={t(locale, 'section.news')} id="news" />
    <NewsList locale={locale} />
  </section>
  <hr />

  <section class="section">
    <SectionTitle title={t(locale, 'section.publications')} id="publications" />
    <ul class="pub-list">
      {pubsWithMeta.map(({ entry, m }) => (
        <PublicationItem
          locale={locale}
          uid={entry.data.paperId}
          title={entry.data.title}
          abstract={entry.data.abstract}
          note={entry.data.note}
          meta={m as any}
        />
      ))}
    </ul>
  </section>

  {projectsSorted.length > 0 && (
    <>
      <hr />
      <section class="section">
        <SectionTitle title={t(locale, 'section.projects')} id="projects" />
        <ul class="project-grid">
          {projectsSorted.map((p) => (
            <ProjectCard
              title={p.data.title}
              summary={p.data.summary}
              cover={p.data.cover}
              link={p.data.link}
            />
          ))}
        </ul>
      </section>
    </>
  )}

  <hr />
  <section class="section">
    <SectionTitle title={t(locale, 'section.reviewer')} id="reviewer" />
    <ReviewerServiceComp />
  </section>
</BaseLayout>

<script>
  import '../scripts/bibtex-copy';
</script>
